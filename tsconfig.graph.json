{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "i18next": ["src/webview/i18next.ts"],
      "react-i18next": ["src/webview/react-i18next.ts"]
    },
    "types": ["node", "vscode", "vite/client", "vitest/globals"]
  },
  "include": ["src/webview", "src/extension", "tests"]
}
