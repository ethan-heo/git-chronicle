{
  "name": "git-chronicle",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.7.0",
  "publisher": "ethanheo",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethan-heo/git-chronicle.git"
  },
  "packageManager": "pnpm@10.19.0",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.0.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "gitChronicle.open",
        "title": "%command.open.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "gitChronicle.savePath": {
          "type": "string",
          "default": "",
          "description": "%configuration.savePath.description%"
        },
        "gitChronicle.activeAIProvider": {
          "type": "string",
          "enum": [
            "",
            "claude",
            "gemini",
            "codex"
          ],
          "default": "",
          "description": "%configuration.activeAIProvider.description%"
        }
      }
    }
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:watch": "vite build --watch",
    "build": "vite build && pnpm build:ext && pnpm build:depcruiser",
    "build:ext": "esbuild src/extension/index.ts --bundle --platform=node --target=node18 --external:vscode --outfile=dist/extension/index.js --sourcemap",
    "build:depcruiser": "node scripts/copy-dependency-cruiser.mjs && node -e \"require('fs').copyFileSync('src/extension/depcruiser-runner.mjs','dist/depcruiser-runner.mjs')\"",
    "changelog": "conventional-changelog -p conventionalcommits -n scripts/changelog.config.cjs -u -r 0 > CHANGELOG.md",
    "changelog:release": "conventional-changelog -p conventionalcommits -n scripts/changelog.config.cjs -r 0 > CHANGELOG.md",
    "release": "bumpp && pnpm changelog:release && git add CHANGELOG.md && git diff --cached --quiet || git commit -m \"chore: update CHANGELOG\"",
    "release:patch": "bumpp patch && pnpm changelog:release && git add CHANGELOG.md && git diff --cached --quiet || git commit -m \"chore: update CHANGELOG\"",
    "release:minor": "bumpp minor && pnpm changelog:release && git add CHANGELOG.md && git diff --cached --quiet || git commit -m \"chore: update CHANGELOG\"",
    "release:major": "bumpp major && pnpm changelog:release && git add CHANGELOG.md && git diff --cached --quiet || git commit -m \"chore: update CHANGELOG\"",
    "package": "pnpm build && npx vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:extension": "vscode-test",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.extension.json --noEmit"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.8.4",
    "dependency-cruiser": "^17.1.0",
    "i18next": "^25.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.7.0",
    "react-markdown": "^10.1.0",
    "shiki": "^3.7.0",
    "simple-git": "^3.28.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-react": "^4.5.2",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^10.4.1",
    "conventional-changelog-cli": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
